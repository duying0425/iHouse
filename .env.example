# AI 图片识别（服务端配置，切勿使用 VITE_ 前缀或提交真实 Key）
# 部署：复制为 .env、限制文件权限（chmod 600 .env），然后 docker compose up -d --build。
# 修改后需 docker compose up -d --force-recreate，单纯 restart 不会替换容器环境变量。
# 填 API 根地址即可；程序会自动补全 /v1/chat/completions。
AI_API_BASE_URL=https://your-new-api.example.com
AI_API_KEY=replace-with-your-api-key
AI_MODEL=openai/gpt-5.6-sol

# 可选：若供应商给的是完整接口地址，可用此项覆盖 AI_API_BASE_URL。
# AI_API_URL=https://your-new-api.example.com/v1/chat/completions

# 可选：识别超时，单位毫秒；允许范围 5000-120000。
AI_TIMEOUT_MS=60000

# 可选：Cloudflare Turnstile 人机验证（双向配置后用户注册页将强制启用人机校验，以防止机器批量注册）
# TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
# TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret-key
# 可选：人机验证验证接口，用于国内或网络限制环境反代
# TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

